# ──────────────────────────────────────────────────────────────────────
# 백안맛지도 .gitignore
# 모노레포 구성: app/web(Next.js) · app/api(FastAPI) · data(Python) · database · config
# ──────────────────────────────────────────────────────────────────────

# ── 시크릿 ────────────────────────────────────────────────────────────
config/secrets.json
*.pem
*.key

# ── 환경변수 (example 만 추적) ────────────────────────────────────────
.env
.env.*
!.env.*.example

# ── Python (app/api, data) ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.ipynb_checkpoints/

# ── Node.js / Next.js (app/web) ───────────────────────────────────────
app/web/node_modules/
app/web/.next/
app/web/out/
app/web/.vercel/
app/web/next-env.d.ts
app/web/tsconfig.tsbuildinfo
app/web/.turbo/
app/web/*.log

# 프로젝트 어디서든 실수로 생긴 node_modules 방지
node_modules/

# ── 데이터 수집 산출물 ────────────────────────────────────────────────
data/logs/*.log
data/.cache/
!data/logs/.gitkeep

# ── OS / Editor ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*~
